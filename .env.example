# ============================================================
# fact_checker - environment variable reference
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Required: OpenRouter LLM API
# Get your key at https://openrouter.ai/keys
# ----------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Global fallback model (used if per-task overrides are not set)
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ----------------------------------------------------------
# Optional: Per-task model overrides
# Defaults come from MODEL_REGISTRY in config.py.
# Uncomment and set to override a specific pipeline stage.
# ----------------------------------------------------------
# MODEL_EXTRACTION=openai/gpt-oss-120b:free
# MODEL_VERIFICATION=nvidia/nemotron-3-ultra-253b:free
# MODEL_ORCHESTRATION=nvidia/nemotron-3-super-49b-v1:free
# MODEL_MULTIMODAL=nvidia/llama-3.1-nemotron-nano-8b-v1:free
# MODEL_TOOLUSE=cohere/north-mini-code:free
# MODEL_FAST=openai/gpt-oss-20b:free

# ----------------------------------------------------------
# Required: PostgreSQL database
# Format: postgresql+asyncpg://user:password@host:port/dbname
# ----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://fact_checker:password@localhost:5432/fact_checker

# ----------------------------------------------------------
# Optional: API key to protect REST endpoints
# If blank/unset, auth is disabled (fine for local dev).
# Set to a strong random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------
API_KEY=

# ----------------------------------------------------------
# Optional: Evidence retrieval APIs
# Google Fact Check Tools: https://developers.google.com/fact-check/tools/api
# Serper (Google Search API): https://serper.dev
# At least one is recommended for non-trivial fact-checking.
# ----------------------------------------------------------
GOOGLE_FACTCHECK_API_KEY=
SERPER_API_KEY=

# ----------------------------------------------------------
# Optional: Whisper ASR
# Used when yt-dlp cannot retrieve captions from the source.
# whisper_model_size: tiny | base | small | medium | large-v3
# whisper_device: cpu | cuda  (set cuda if you have a GPU)
# whisper_compute_type: int8 | float16 | float32
# ----------------------------------------------------------
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ----------------------------------------------------------
# Optional: FastAPI server
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ----------------------------------------------------------
# Optional: Storage paths
# ----------------------------------------------------------
ARTIFACT_DIR=./artifacts
MEDIA_CACHE_DIR=./media_cache
