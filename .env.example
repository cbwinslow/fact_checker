# ── OpenRouter ──────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=nvidia/nemotron-ultra-253b-v1:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fact_checker:password@localhost:5432/fact_checker

# ── Whisper ASR ──────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── App ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
ARTIFACT_DIR=./artifacts
MEDIA_CACHE_DIR=./media_cache

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Evidence / Search ────────────────────────────────────────
# Optional: Google Fact Check API key
GOOGLE_FACTCHECK_API_KEY=
# Optional: Serper.dev for web evidence retrieval
SERPER_API_KEY=
